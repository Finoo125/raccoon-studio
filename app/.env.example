# ComfyUI connection — change only if ComfyUI runs on a different host or port
COMFYUI_BASE_URL=http://127.0.0.1:8188

# Path to ComfyUI's output directory (where generated images are saved)
# Linux / macOS example:
COMFYUI_OUTPUT_DIR=/home/YOUR_USERNAME/AI/ComfyUI/ComfyUI/output
# Windows 11 example (use forward slashes):
# COMFYUI_OUTPUT_DIR=C:/Users/YOUR_USERNAME/ComfyUI/ComfyUI/output

# Path to ComfyUI's models directory
# Linux / macOS example:
COMFYUI_MODELS_DIR=/home/YOUR_USERNAME/AI/ComfyUI/ComfyUI/models
# Windows 11 example (use forward slashes):
# COMFYUI_MODELS_DIR=C:/Users/YOUR_USERNAME/ComfyUI/ComfyUI/models

# Path to your ComfyUI start script (enables the Start button in the sidebar)
# Linux / macOS example:
COMFYUI_START_SCRIPT=/home/YOUR_USERNAME/AI/ComfyUI/start-comfyui.sh
# Windows 11 example:
# COMFYUI_START_SCRIPT=C:/ComfyUI/run_nvidia_gpu.bat

# Ollama connection — used by the Director AI film pipeline for storyboard generation
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Per-request timeout (ms) for storyboard generation. A slow/unsuitable model
# (e.g. a large base model that can't satisfy the JSON grammar) aborts with a
# clear error instead of hanging. Default 180000 (3 min).
# OLLAMA_TIMEOUT_MS=180000
# Context window for storyboard generation. Models default to a huge native
# context whose KV cache can exceed VRAM and force Ollama to run on CPU; a
# storyboard needs very little, so this is capped to keep the model on the GPU.
# Raise it only for very long plots. Default 8192.
# OLLAMA_NUM_CTX=8192
