# ── Root build/cache artifacts (not source) ─────────────────────────────────
/node_modules/
/.next/

# ── App (Next.js) ────────────────────────────────────────────────────────────
app/node_modules/
app/.pnp
app/.pnp.*
app/.yarn/
app/coverage/
app/.next/
app/out/
app/build/
app/.vercel
app/*.tsbuildinfo
app/next-env.d.ts
app/.env.local
app/.env.*.local
app/.env.local.bak

# ── ComfyUI installation (installed fresh by the installer, never committed) ───
# Ignore the whole checkout; vendored nodes live in comfyui/vendor-custom-nodes/.
comfyui/ComfyUI/

# ── Generated by installers ───────────────────────────────────────────────────
start-comfyui.sh
start-comfyui.ps1
start-comfyui.bat
start.sh
start.bat
stop.sh
stop.bat
stop.ps1
raccoon-studio.ico
# Anchored: unanchored "logs/" also swallowed app/src/app/(studio)/logs/ and api/logs/.
/logs/

# ── Runtime app state (queue/history persistence, machine-specific) ───────────
/data/

# ── Tooling scratch ──────────────────────────────────────────────────────────
.superpowers/

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Add-on creator keys ────────────────────────────────────────────────────────
scripts/keys/
app/.entitlements.json
__pycache__/
worker/node_modules/
